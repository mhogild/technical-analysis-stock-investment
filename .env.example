# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend
BACKEND_URL=http://localhost:8000

# Email (for notifications - Phase 7)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Saxo OpenAPI
SAXO_APP_KEY=your-saxo-app-key
SAXO_APP_SECRET=your-saxo-app-secret
SAXO_REDIRECT_URI=http://localhost:8000/api/saxo/auth/callback
SAXO_ENVIRONMENT=sim
SAXO_TOKEN_ENCRYPTION_KEY=generate-with-python-cryptography-fernet-generate-key
SAXO_FRONTEND_REDIRECT_URL=http://localhost:3000/settings?saxo=connected
